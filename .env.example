# ── SEO MCP server configuration ──────────────────────────────────────────
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# Port the Node process listens on (behind your reverse proxy).
PORT=3000

# Bearer tokens the team uses to reach /mcp. Comma-separated so you can issue
# one token per teammate and revoke individually. Generate strong random values,
# e.g.  openssl rand -hex 32
MCP_AUTH_TOKENS=replace-with-a-long-random-token,another-token-for-someone-else

# Hostnames allowed in the Host header (DNS-rebinding protection).
# MUST match exactly what clients send, INCLUDING port if non-standard.
# Behind HTTPS on your domain this is just the domain (no port):
#   MCP_ALLOWED_HOSTS=domain.com
# For local testing on a custom port, include the port:
#   MCP_ALLOWED_HOSTS=localhost:3000,127.0.0.1:3000
MCP_ALLOWED_HOSTS=domain.com

# ── Google service-account credentials ────────────────────────────────────
# Provide exactly ONE of the following three.

# Option A — path to the service-account JSON key file (simplest for VPS/Docker):
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/service-account.json

# Option B — raw JSON string (single line). Handy for some PaaS dashboards:
# GOOGLE_CREDENTIALS_JSON={"type":"service_account", ... }

# Option C — base64-encoded JSON (avoids quoting/newline issues in env vars):
#   base64 -w0 service-account.json
# GOOGLE_CREDENTIALS_BASE64=eyJ0eXBlIjoic2Vydmlj...
