# ── SEO MCP server configuration ──────────────────────────────────────────
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# Port the Node process listens on (behind your reverse proxy).
PORT=3000

# Static bearer tokens for reaching /mcp directly with a header — used by
# Claude Code CLI and Claude Desktop. Comma-separated (one per teammate so you
# can revoke individually). Generate strong values, e.g. openssl rand -hex 32
#
# OPTIONAL: leave this unset/commented to disable static-token access entirely
# and require OAuth (browser connector) for everyone. If you do, you MUST set
# MCP_OAUTH_PASSWORD below so the consent screen has a credential to accept.
# MCP_AUTH_TOKENS=replace-with-a-long-random-token,another-token-for-someone-else

# Hostnames allowed in the Host header (DNS-rebinding protection).
# MUST match exactly what clients send, INCLUDING port if non-standard.
# Behind HTTPS on your domain this is just the domain (no port):
#   MCP_ALLOWED_HOSTS=domain.com
# For local testing on a custom port, include the port:
#   MCP_ALLOWED_HOSTS=localhost:3000,127.0.0.1:3000
MCP_ALLOWED_HOSTS=domain.com

# ── Browser OAuth (custom connector on claude.ai) ──────────────────────────
# Only needed if you want to add this server via the "Add custom connector"
# dialog in the claude.ai browser app. That dialog requires OAuth; the vars
# below turn this server into its own OAuth authorization server. Claude Code
# CLI and Claude Desktop do NOT need these — they use MCP_AUTH_TOKENS directly.
#
# When set, "Connect" in the browser opens a consent screen hosted here where
# the user enters either MCP_OAUTH_PASSWORD or one of the MCP_AUTH_TOKENS.
# Leave OAuth Client ID/Secret blank in the claude.ai dialog (Claude self-registers).
#
# This is UNRELATED to the Google OAuth below.

# Public origin of THIS server (https, no trailing slash, no path).
# Enables OAuth mode together with MCP_OAUTH_JWT_SECRET.
# MCP_PUBLIC_URL=https://domain.com

# Secret used to sign OAuth tokens. Generate a strong random value:
#   openssl rand -hex 32
# MCP_OAUTH_JWT_SECRET=replace-with-a-long-random-secret

# Shared team password accepted on the consent screen (alongside any
# MCP_AUTH_TOKENS). Friendlier to type than a long token. REQUIRED if you leave
# MCP_AUTH_TOKENS unset (otherwise the consent screen has nothing to accept).
# MCP_OAUTH_PASSWORD=some-team-password

# Nothing to configure in Google Cloud for this: Claude's redirect URI
# (https://claude.ai/api/mcp/auth_callback) is registered automatically via DCR.

# ── Google authentication ─────────────────────────────────────────────────
# Two modes. If the OAUTH vars are set, the server uses OAuth (authenticates AS
# a central Google account). Otherwise it falls back to the service account.

# ── Mode 1: OAuth "central account" (recommended for agencies) ─────────────
# The server acts as ONE Google account (e.g. your agency Gmail) that clients
# add as a Viewer to their GA4/GSC. Every property that account can see becomes
# readable automatically — no per-client service-account grant.
#
# Get these:
#   1. Google Cloud → APIs & Services → Credentials → Create OAuth client ID
#      (Web application). Add redirect URI: http://localhost:5555/oauth2callback
#   2. Put the client id/secret below, then run:  npm run oauth:login
#      Log in as the CENTRAL account; paste the printed refresh token here.
# GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=xxxxxxxx
# GOOGLE_OAUTH_REFRESH_TOKEN=1//xxxxxxxx

# ── Mode 2: Service account (fallback) ─────────────────────────────────────
# Provide exactly ONE of the following three. Clients must add the service
# account's robot email (…iam.gserviceaccount.com) to their properties.

# Option A — path to the service-account JSON key file (simplest for VPS/Docker):
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/service-account.json

# Option B — raw JSON string (single line). Handy for some PaaS dashboards:
# GOOGLE_CREDENTIALS_JSON={"type":"service_account", ... }

# Option C — base64-encoded JSON (avoids quoting/newline issues in env vars):
#   base64 -w0 service-account.json
# GOOGLE_CREDENTIALS_BASE64=eyJ0eXBlIjoic2Vydmlj...
